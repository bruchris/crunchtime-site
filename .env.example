# Contact form → email handoff (Resend free tier: 100/day)
# Sign up at https://resend.com/, verify crunchtime.no, get API key.
RESEND_API_KEY=re_xxx

# Where contact form submissions land (Zoho shared inbox).
CONTACT_INBOX=hello@crunchtime.no

# Sender address for transactional form emails.
CONTACT_FROM="Crunchtime <noreply@crunchtime.no>"

# Cal.com booking link for Discovery Sprint CTA (legacy: used by /contact).
NEXT_PUBLIC_CAL_BOOKING_LINK=https://cal.com/crunchtime/discovery-sprint

# Cal.com 15-min fit call — primary CTA on /consulting. Falls back to
# NEXT_PUBLIC_CAL_BOOKING_LINK if unset. Provision as a free event type on
# the Crunchtime Cal.com org once CRUA-40 unblocks deploy.
NEXT_PUBLIC_CAL_FIT_CALL_LINK=https://cal.com/crunchtime/fit-call
